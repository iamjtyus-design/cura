{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://visionbuilt.example/schemas/output-pack-1.0.json",
  "title": "CURA Output Pack",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "session_id",
    "curated_note_id",
    "pack_key",
    "pack_name",
    "mode",
    "language",
    "outputs"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "session_id": {
      "type": "string",
      "format": "uuid"
    },
    "curated_note_id": {
      "type": "string",
      "format": "uuid"
    },
    "pack_key": {
      "type": "string"
    },
    "pack_name": {
      "type": "string"
    },
    "mode": {
      "enum": [
        "learn",
        "create",
        "work"
      ]
    },
    "language": {
      "type": "string"
    },
    "outputs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "output_id",
          "output_type",
          "title",
          "content",
          "status",
          "evidence_references"
        ],
        "properties": {
          "output_id": {
            "type": "string",
            "format": "uuid"
          },
          "output_type": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "platform": {
            "type": [
              "string",
              "null"
            ]
          },
          "audience": {
            "type": [
              "string",
              "null"
            ]
          },
          "tone": {
            "type": [
              "string",
              "null"
            ]
          },
          "content": {
            "type": [
              "string",
              "object",
              "array"
            ]
          },
          "status": {
            "enum": [
              "generated",
              "edited",
              "approved",
              "exported"
            ]
          },
          "inference_labels": {
            "type": "array",
            "items": {
              "enum": [
                "explicit",
                "strong_inference",
                "suggestion",
                "uncertain"
              ]
            }
          },
          "evidence_references": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "source_id",
                "confidence"
              ],
              "properties": {
                "source_id": {
                  "type": "string",
                  "format": "uuid"
                },
                "start_ms": {
                  "type": [
                    "integer",
                    "null"
                  ],
                  "minimum": 0
                },
                "end_ms": {
                  "type": [
                    "integer",
                    "null"
                  ],
                  "minimum": 0
                },
                "frame_timestamp_ms": {
                  "type": [
                    "integer",
                    "null"
                  ],
                  "minimum": 0
                },
                "page_number": {
                  "type": [
                    "integer",
                    "null"
                  ],
                  "minimum": 1
                },
                "text_range": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "evidence_text": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "confidence": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1
                }
              }
            }
          }
        }
      }
    }
  }
}
